Scenario 1: Age Above 60 → 1% Discount
UPDATE Loans l
JOIN Customers c ON l.customerId = c.customerId
SET l.interestRate = l.interestRate - 1
WHERE c.age > 60;
SELECT * FROM Loans;

Scenario 2: Balance Above 10000 → VIP TRUE
UPDATE Customers
SET isVIP = TRUE
WHERE balance > 10000;
SELECT * FROM Customers;

Scenario 3: Loans Due Within Next 30 Days
SELECT 
    c.customerName,
    l.loanId,
    l.dueDate,
    CONCAT('Reminder: Loan ', l.loanId, ' is due on ', l.dueDate) AS ReminderMessage
FROM Loans l
JOIN Customers c ON l.customerId = c.customerId
WHERE l.dueDate BETWEEN CURDATE() AND CURDATE() + INTERVAL 30 DAY;
